* Chernobyl run

TIME.START=  1986 04 25 21 00
POSITIONS.DECIMAL
SET_RELEASE.POS= P=   51.389853, 30.094047
TIME.RUN = 168 h
TIME.STEP= 90.0

ASYNC_IO.ON

RANDOM.WALK.ON
* RANDOM.WALK.OFF

* BOUNDARY.LAYER.FULL.MIX.ON
BOUNDARY.LAYER.FULL.MIX.OFF

DRY.DEPOSITION.SCHEME = emerson

DRY.DEPOSITION.LARGEST_LANDFRACTION_FILE=/lustre/storeB/project/fou/kl/cerad/Meteorology/AROME-CHERNOBYL/surfex/LargestFraction.nc

*** particles distributed on components according to mass
MAX.PARTICLES.PER.RELEASE= 1000
MAX.TOTALPARTICLES=20000000
MAX.TOTALPLUMES=2000000
PARTICLES.SPLIT.HOURS=72
REMOVE.RELATIVE.MASS.LIMIT= 0.02
RANDOM.SEED = 0

COMPONENT= Cs137
DRY.DEP.ON
WET.DEP.ON
RADIOACTIVE.DECAY.ON
RADIUS.MICROMETER=0.5
DENSITY.G/CM3=2.3
HALF.LIFETIME.YEARS= 30
*GRAVITY.FIXED.M/S=0.0002


STEP.HOUR.INPUT.MIN=  1
STEP.HOUR.INPUT.MAX=  3
STEP.HOUR.OUTPUT.FIELDS=1

TOTAL.COMPONENTS.OFF
