***********************************************************************
*** snap.input  ('snap.input')
***
*** DNMI SNAP - Severe Nuclear Accident Program
***********************************************************************

* second cell
SET_RELEASE.POS= P=   54.9219994632992, 10.0741517222782
POSITIONS.DECIMAL
TIME.START= 2025 11 25 07
TIME.RUN = 1h
TIME.RELEASE.PROFILE.BOMB
MAX.PARTICLES.PER.RELEASE= 1000
MAX.TOTALPARTICLES= 2000000
RELEASE.HOUR= 0
RELEASE.RADIUS.M= 50
RELEASE.LOWER.M= 15
RELEASE.UPPER.M= 500
RELEASE.BQ/SEC.COMP= 2.6e+11, 'Cs137'

***List of components
COMPONENT= Cs137
RADIOACTIVE.DECAY.ON
HALF.LIFETIME.DAYS= 1.10048516E+04
DRY.DEP.ON
WET.DEP.ON
* very large for immediate deposition
RADIUS.MICROMETER=200
DENSITY.G/CM3=2.3
GRAVITY.FIXED.M/S=0.0002

RANDOM.WALK.ON
FORWARD.OFF
*
* BOUNDARY.LAYER.FULL.MIX.ON
BOUNDARY.LAYER.FULL.MIX.OFF
*
DRY.DEPOSITION.SCHEME = NEW
*DRY.DEPOSITION.LARGEST_LANDFRACTION_FILE = ../../../utils/SnapPy/Snappy/resources/landfractions/largestLandFraction_Meps2p5.nc

WET.DEPOSITION.SCHEME = bartnicki
*
REMOVE.RELATIVE.MASS.LIMIT= 0.
*
TIME.STEP= 60.
STEP.HOUR.INPUT.MIN=  1
* STEP.HOUR.INPUT.MIN=  6
STEP.HOUR.INPUT.MAX= 3
*STEP.HOUR.OUTPUT.FIELDS= 240
STEP.HOUR.OUTPUT.FIELDS= 1
ASYNOPTIC.OUTPUT
*SYNOPTIC.OUTPUT
*
TOTAL.COMPONENTS.OFF
* TOTAL.COMPONENTS.ON
MSLP.OFF
PRECIPITATION.ON
MODEL.LEVEL.FIELDS.OFF
* MODEL.LEVEL.FIELDS.ON
*
** INPUT FIELD FILES
FIELD.TYPE=fimex
FIELD.INPUT= ../snap_testdata/meps_det_2_5km_20251125T06Z_ringhals.nc
** USE FIMEX
FIMEX.FILE_TYPE= netcdf
*FIMEX.CONFIG=

** GRID INPUT AND RUN, MODEL LEVELS INPUT (0,KS,KS-1,........1)
GRID.NCTYPE = arome
DATA.ETA.LEVELS
ENSEMBLE_MEMBER.INPUT = 0

GRID.AUTODETECT.FROM_INPUT

*
** IDENTIFY OUTPUT FIELDS WITH FORECAST LENGTH OR VALID TIME
*
FIELD_TIME.FORECAST
* FIELD_TIME.VALID
*
** OUTPUT FILES
*
FIELD.OUTTYPE=netcdf
FIELD.OUTPUT= snap.nc
LOG.FILE=     snap.log
*
* DEBUG.OFF
DEBUG.ON
