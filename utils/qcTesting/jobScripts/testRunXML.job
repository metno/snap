elif [ $SGE_TASK_ID -eq 10 ]; then
    mkdir nuclideEC
    echo "start work nuclide EC" >> "$LOGFILE"

    RIMSTERM_XML=$SNAPQCDIR/Detonation-Ringhals_Rimsterm.xml
    ARGOS_REQUEST=$SNAPQCDIR/EC_bomb_SNAP_request.xml
    IDENT=nuclideEC
    METMODEL=nrpa_ec_0p1
    DIR=./nuclideEC
    OPS=

elif [ $SGE_TASK_ID -eq 11 ]; then
    mkdir nuclideMEPS

    RIMSTERM_XML=$SNAPQCDIR/Detonation-Ringhals_Rimsterm.xml
    ARGOS_REQUEST=$SNAPQCDIR/MEPS_bomb_SNAP_request.xml
    IDENT=nuclideMEPS
