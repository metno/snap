    ARGOS_REQUEST=$SNAPQCDIR/MEPS_backTrack_SNAP_request.xml
    IDENT=backTrackMEPS
    METMODEL=meps_2_5km
    DIR=./backTrackMEPS
    OPS=

elif [ $SGE_TASK_ID -eq 9 ]; then
    mkdir backTrackICON
   
    RIMSTERM_XML=$SNAPQCDIR/RinghalsBackTrack_Rimsterm.xml
    ARGOS_REQUEST=$SNAPQCDIR/ICON_backTrack_SNAP_request.xml
    IDENT=backTrackICON
