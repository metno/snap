# cd $LUSTRE/$VDIR
# mkdir ChernobylMEPS
# echo "start work ChernobylMEPS MEPS" >> "$LOGFILE"
# cd ChernobylMEPS
#export OMP_NUM_THREADS=4
# bsnap_naccident $HOME/snap/utils/qcTesting/input/ChernobylMEPS.input

snap4rimsterm --rimsterm $RIMSTERM_XML --argosrequest $ARGOS_REQUEST $OPS --dir $DIR --ident $IDENT --metmodel $METMODEL

