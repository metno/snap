elif [ $SGE_TASK_ID -eq 16 ]; then
    mkdir SunbeamSmallBoy

    RIMSTERM_XML=$SNAPQCDIR/SunbeamSmallboy_Rimsterm.xml
    ARGOS_REQUEST=$SNAPQCDIR/SunbeamSmallboy_SNAP_request.xml
    IDENT=SunbeamSmallboy
