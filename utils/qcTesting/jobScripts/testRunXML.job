#! /bin/bash
#$ -N QC-dev-run
#$ -S /bin/bash
#$ -q bigmem-r8.q,research-r8.q,researchlong-r8.q,researchshort-r8.q #Operational eventually?
#$ -pe shmem-1 1
#$ -l h_rss=20G,mem_free=20G,h_data=20G
#$ -l h_rt=4:00:00
#$ -v STORE,SNAPPY
#$ -M geche8548@met.no
#$ -m abe
#$ -P dsa
#$ -o /home/geche8548/snap-runs/QC-dev/test-job-runs
#$ -e /home/geche8548/snap-runs/QC-dev/test-job-runs
#$ -t 1-16 

umask 0002
# ~4 mio particles, use 2 (hyper-) threads
export OMP_NUM_THREADS=2
export OMP_THREAD_LIMIT=2
export OPENBLAS_NUM_THREADS=1
export MAGICK_THREAD_LIMIT=1

module load --silent /modules/MET/rhel8/user-modules/fou-modules/SnapPy/"$SNAPPY"

set -x

LUSTRE=/lustre/storeB/project/fou/kl/cerad/Projects/QC/ModelRuns/
SNAPQCDIR=/home/geche8548/snap/utils/qcTesting/input/xml-requests
VDIR=v$SNAPPY

cd $LUSTRE/$VDIR

if [ $SGE_TASK_ID -eq 1 ]; then
    mkdir RinghalsRainyMeps

    RIMSTERM_XML=$SNAPQCDIR/RinghalsRainy_Rimsterm.xml
    ARGOS_REQUEST=$SNAPQCDIR/MEPS_SNAP_request.xml
    IDENT=RinghalsRainyMEPS
    METMODEL=meps_2_5km
    DIR=./RinghalsRainyMeps
    OPS=

elif [ $SGE_TASK_ID -eq 2 ]; then
    mkdir RinghalsRainyEC 

    RIMSTERM_XML=$SNAPQCDIR/RinghalsRainy_Rimsterm.xml
    ARGOS_REQUEST=$SNAPQCDIR/EC_SNAP_request.xml
    IDENT=RinghalsRainyEC
    METMODEL=nrpa_ec_0p1
    DIR=./RinghalsRainyEC
    OPS=

elif [ $SGE_TASK_ID -eq 3 ]; then
    mkdir RinghalsRainyICON

    RIMSTERM_XML=$SNAPQCDIR/RinghalsRainy_Rimsterm.xml
    ARGOS_REQUEST=$SNAPQCDIR/ICON_SNAP_request.xml
    IDENT=RinghalsRainyICON
    METMODEL=icon_0p25_global
    DIR=./RinghalsRainyICON
    OPS=

elif [ $SGE_TASK_ID -eq 4 ]; then
    mkdir RinghalsDryMeps

