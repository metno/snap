    METMODEL=nrpa_ec_0p1
    DIR=./RinghalsDryEC
    OPS=

elif [ $SGE_TASK_ID -eq 6 ]; then
    mkdir RinghalsDryICON
    
    RIMSTERM_XML=$SNAPQCDIR/RinghalsDry_Rimsterm.xml
    ARGOS_REQUEST=$SNAPQCDIR/ICON_SNAP_request.xml
    IDENT=RinghalsDryICON
    METMODEL=icon_0p25_global
    DIR=./RinghalsDryICON
    OPS=

elif [ $SGE_TASK_ID -eq 7 ]; then
    mkdir backTrackEC

    RIMSTERM_XML=$SNAPQCDIR/RinghalsBackTrack_Rimsterm.xml
    ARGOS_REQUEST=$SNAPQCDIR/EC_backTrack_SNAP_request.xml
    IDENT=backTrackEC
    METMODEL=nrpa_ec_0p1
