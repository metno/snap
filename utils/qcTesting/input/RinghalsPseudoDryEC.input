FIELD.INPUT= /lustre/storeB/project/fou/kl/cerad/Meteorology/QC/RINGHALS_DRY/EC/NRPA_EUROPE_0_1_00/meteo20260708_00.nc
FIELD.INPUT= /lustre/storeB/project/fou/kl/cerad/Meteorology/QC/RINGHALS_DRY/EC/NRPA_EUROPE_0_1_00/meteo20260709_00.nc

***********************************************************************
*** MET Norway SNAP input file derived from snap.input_nrpa_ec_0p1.tmpl
***********************************************************************

RANDOM.WALK.ON

BOUNDARY.LAYER.FULL.MIX.OFF

DRY.DEPOSITION.SCHEME = emerson
DRY.DEPOSITION.LARGEST_LANDFRACTION_FILE = /modules/rhel8/user-apps/fou-modules/SnapPy/2.5.25/lib/python3.12/site-packages/Snappy/resources/landfractions/largestLandFraction_NrpaEC0p1.nc

WET.DEPOSITION.SCHEME = bartnicki

*** particles distributed on components according to mass
MAX.TOTALPARTICLES= 20000000


REMOVE.RELATIVE.MASS.LIMIT= 0.

TIME.STEP= 300.
STEP.HOUR.INPUT.MIN=  3
STEP.HOUR.INPUT.MAX= 6
ASYNOPTIC.OUTPUT
*SYNOPTIC.OUTPUT

TOTAL.COMPONENTS.OFF
* TOTAL.COMPONENTS.ON
MSLP.OFF
PRECIPITATION.ON
MODEL.LEVEL.FIELDS.OFF
* MODEL.LEVEL.FIELDS.ON

POSITIONS.DECIMAL

FIELD.TYPE=fimex
FIMEX.FILE_TYPE= netcdf
FIMEX.CONFIG=


** ECRead output
GRID.NCTYPE = ecemep
DATA.ETA.LEVELS
GRID.AUTODETECT.FROM_INPUT


** IDENTIFY OUTPUT FIELDS WITH FORECAST LENGTH OR VALID TIME
FIELD_TIME.FORECAST
** OUTPUT FILES

FIELD.OUTTYPE=netcdf
FIELD.OUTPUT= snap.nc
LOG.FILE=     snap.log

* DEBUG.OFF
DEBUG.ON

OUTPUT.COLUMN.ON
* OUTPUT.AIRCRAFT_DOSERATE.ENABLE
* Tiltaksgrense Avsperring
* Se Sivilforsvaret Bestemmelser om sikkerhet under opplæring, øving og
* innsats i Sivilforsvaret
* Grense i Sv/h
OUTPUT.AIRCRAFT_DOSERATE.THRESHOLD.SV_H = 60e-6
